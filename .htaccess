# ==========================================================================
# AGER GROUP — configuration Apache
# Déposez ce fichier à la racine du site. Si votre hébergeur utilise Nginx,
# demandez-lui l'équivalent (voir README.md).
# ==========================================================================

# --- Page d'erreur personnalisée -----------------------------------------
ErrorDocument 404 /404.html

# --- Page d'accueil par défaut -------------------------------------------
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Forcer HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # Retirer le www
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

  # URL sans extension : /contact affiche contact.html
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}\.html -f
  RewriteRule ^(.*)$ $1.html [L]
</IfModule>

# --- Protection des fichiers internes ------------------------------------
<FilesMatch "\.(log|py|md|bak|ini|sql)$">
  Require all denied
</FilesMatch>

<Files ".htaccess">
  Require all denied
</Files>

# --- En-têtes de sécurité ------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self'; form-action 'self'; frame-ancestors 'self'; base-uri 'self'"
</IfModule>

# --- Compression ---------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# --- Cache navigateur ----------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html                 "access plus 1 hour"
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
</IfModule>

# --- Encodage ------------------------------------------------------------
AddDefaultCharset UTF-8
